# World Models Hub - 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# ============================================
# Kimi API (Moonshot AI) - 必需
# 用于AI内容处理：标题翻译、摘要生成、分类标注、评分等
# 获取地址: https://platform.moonshot.cn/
# ============================================
KIMI_API_KEY=your_kimi_api_key_here

# ============================================
# GitHub Token - 可选
# 用于提高GitHub API的访问限流（默认60次/小时，认证后5000次/小时）
# 获取地址: https://github.com/settings/tokens
# ============================================
GITHUB_TOKEN=your_github_token_here

# ============================================
# 可选：Kimi模型配置
# 可选值: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k
# ============================================
# KIMI_MODEL=moonshot-v1-8k
